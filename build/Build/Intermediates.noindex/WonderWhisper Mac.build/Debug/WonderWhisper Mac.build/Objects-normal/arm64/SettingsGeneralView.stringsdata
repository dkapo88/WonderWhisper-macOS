        }
      },
      {
        "comment": "",
        "key": "Choose file size vs. compatibility. MP3/AAC upload faster; WAV is largest but widely supported.",
        "location": {
          "startingColumn": 38,
          "startingLine": 63
        }
      },
      {
        "comment": "",
        "key": "Useful if your network has trouble with HTTP/3/QUIC. Leave off unless uploads stall.",
