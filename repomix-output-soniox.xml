  return (
    <ModelDataProvider>
      <ComparisonProvider>
        <MainLayout
          sidebarContent={<ControlPanel />}
          mainContent={<ProviderGrid />}
          featureTableContent={<FeatureComparisonTable />}
        />
      </ComparisonProvider>
    </ModelDataProvider>
  );
}

export default App;
