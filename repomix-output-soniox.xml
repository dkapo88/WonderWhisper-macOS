COPY pyproject.toml uv.lock .python-version .
RUN uv sync --locked

# Copy the project into the image
ADD . .

COPY --from=fe-builder /app/dist /app/frontend/dist

ARG VERSION
ENV VERSION=${VERSION}

CMD ["uv", "run", "fastapi", "run"]
